import smbus2
import time

MPU6050_ADDR = 0x68  
PWR_MGMT_1   = 0x6B
SMPLRT_DIV   = 0x19
CONFIG       = 0x1A
GYRO_CONFIG  = 0x1B
ACCEL_CONFIG = 0x1C

ACCEL_XOUT_H = 0x3B
ACCEL_YOUT_H = 0x3D
ACCEL_ZOUT_H = 0x3F
TEMP_OUT_H   = 0x41
GYRO_XOUT_H  = 0x43
GYRO_YOUT_H  = 0x45
GYRO_ZOUT_H  = 0x47

# Sensitivity scale factors (for default full-scale range)
ACCEL_SCALE = 16384.0   # LSB/g for +-2g
GYRO_SCALE  = 131.0     # LSB/(deg/s) for +-250 deg/s

bus = smbus2.SMBus(1)  # I2C bus 1 on Raspberry Pi


def mpu6050_init():
    # Wake up the MPU6050 (it starts in sleep mode)
    bus.write_byte_data(MPU6050_ADDR, PWR_MGMT_1, 0x00)
    time.sleep(0.1)
    bus.write_byte_data(MPU6050_ADDR, SMPLRT_DIV, 0x07)
    bus.write_byte_data(MPU6050_ADDR, CONFIG, 0x00)
    bus.write_byte_data(MPU6050_ADDR, GYRO_CONFIG, 0x00)   # +-250 deg/s
    bus.write_byte_data(MPU6050_ADDR, ACCEL_CONFIG, 0x00)  # +-2g


def read_raw_data(addr):
    high = bus.read_byte_data(MPU6050_ADDR, addr)
    low = bus.read_byte_data(MPU6050_ADDR, addr + 1)
    value = (high << 8) | low
    # Convert to signed 16-bit
    if value > 32768:
        value -= 65536
    return value


def main():
    print("Initializing MPU6050...")
    mpu6050_init()
    print("Reading data (Ctrl+C to stop)\n")

    try:
        while True:
            acc_x = read_raw_data(ACCEL_XOUT_H) / ACCEL_SCALE
            acc_y = read_raw_data(ACCEL_YOUT_H) / ACCEL_SCALE
            acc_z = read_raw_data(ACCEL_ZOUT_H) / ACCEL_SCALE

            gyro_x = read_raw_data(GYRO_XOUT_H) / GYRO_SCALE
            gyro_y = read_raw_data(GYRO_YOUT_H) / GYRO_SCALE
            gyro_z = read_raw_data(GYRO_ZOUT_H) / GYRO_SCALE

            temp = read_raw_data(TEMP_OUT_H) / 340.0 + 36.53

            print(f"Accel [g]:  X={acc_x:7.3f}  Y={acc_y:7.3f}  Z={acc_z:7.3f}   "
                  f"Gyro [deg/s]: X={gyro_x:8.3f}  Y={gyro_y:8.3f}  Z={gyro_z:8.3f}   "
                  f"Temp={temp:5.2f}C")

            time.sleep(0.5)

    except KeyboardInterrupt:
        print("\nStopped by user.")
    finally:
        bus.close()


if __name__ == "__main__":
    main()

